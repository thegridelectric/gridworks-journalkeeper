# Copy to .env (gitignored) and fill in.
# Settings use GJK_ prefix; nested fields use __ delimiter.

# PostgreSQL — gw_data's `gridworks` database. gw_writer is the right role
# for an app that only inserts rows (gw_admin is reserved for migrations).
# Port 5433 matches gridworks-data's README dev recipe (5432 reserved for
# any native PostgreSQL install). Driver: psycopg2 (per pyproject deps).
GJK_DB_URL=postgresql+psycopg2://gw_writer:<%PASSWORD%>@localhost:5433/gridworks

# Local dev RabbitMQ — see README "RabbitMQ" section for `./x86.sh` boot.
GJK_RABBIT__URL=amqp://smqPublic:smqPublic@localhost:5672/d1__1

# Routable address of this tap (gwbase ServiceSettings.service_alias).
# Defaults to d1.journal; override here if needed.
# GJK_SERVICE_ALIAS=d1.journal
